<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#020b14"/>
      <stop offset="100%" style="stop-color:#03111f"/>
    </linearGradient>
    <linearGradient id="line" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:transparent"/>
      <stop offset="50%" style="stop-color:#00c8ff"/>
      <stop offset="100%" style="stop-color:#ffa500"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- hex pattern overlay -->
  <rect width="1200" height="630" fill="url(#hexpattern)" opacity="0.03"/>

  <!-- border frame -->
  <rect x="24" y="24" width="1152" height="582" fill="none" stroke="#00c8ff" stroke-width="1" stroke-opacity="0.2"/>
  <rect x="30" y="30" width="1140" height="570" fill="none" stroke="#00c8ff" stroke-width="0.5" stroke-opacity="0.1"/>

  <!-- top accent line -->
  <rect x="0" y="0" width="1200" height="3" fill="url(#line)"/>

  <!-- corner marks -->
  <path d="M24,60 L24,24 L60,24" fill="none" stroke="#00c8ff" stroke-width="2" opacity="0.6"/>
  <path d="M1140,24 L1176,24 L1176,60" fill="none" stroke="#00c8ff" stroke-width="2" opacity="0.6"/>
  <path d="M24,570 L24,606 L60,606" fill="none" stroke="#ffa500" stroke-width="2" opacity="0.6"/>
  <path d="M1140,606 L1176,606 L1176,570" fill="none" stroke="#ffa500" stroke-width="2" opacity="0.6"/>

  <!-- logo mark -->
  <g transform="translate(80, 80)">
    <rect width="48" height="48" rx="8" fill="#00c8ff" opacity="0.15" stroke="#00c8ff" stroke-width="1.5"/>
    <rect x="8" y="8" width="14" height="14" rx="2" fill="#00c8ff"/>
    <rect x="26" y="8" width="14" height="14" rx="2" fill="#00c8ff" opacity="0.5"/>
    <rect x="8" y="26" width="14" height="14" rx="2" fill="#00c8ff" opacity="0.5"/>
    <rect x="26" y="26" width="14" height="14" rx="2" fill="#00c8ff" opacity="0.2"/>
  </g>

  <!-- wordmark -->
  <text x="144" y="114" font-family="'Arial', sans-serif" font-size="22" font-weight="900" letter-spacing="8" fill="#b8e4f5" text-anchor="start">DENYSOFT</text>
  <text x="352" y="114" font-family="'Arial', sans-serif" font-size="22" font-weight="900" letter-spacing="8" fill="#00c8ff" text-anchor="start">KB</text>

  <!-- system status -->
  <circle cx="80" cy="180" r="4" fill="#00ff88"/>
  <text x="96" y="185" font-family="monospace" font-size="11" letter-spacing="3" fill="#3a6a85">SYSTEM ONLINE // KNOWLEDGE BASE ACTIVE</text>

  <!-- main headline -->
  <text x="80" y="320" font-family="'Arial', sans-serif" font-size="72" font-weight="900" letter-spacing="-2" fill="#b8e4f5">KNOWLEDGE</text>
  <text x="80" y="405" font-family="'Arial', sans-serif" font-size="72" font-weight="900" letter-spacing="-2" fill="#00c8ff" filter="url(#glow)">BASE</text>

  <!-- descriptor -->
  <text x="80" y="460" font-family="monospace" font-size="14" letter-spacing="2" fill="#3a6a85">TUTORIALES INTERACTIVOS — DISEÑO · MARKETING · IA · DESARROLLO</text>

  <!-- divider -->
  <rect x="80" y="490" width="400" height="1" fill="url(#line)" opacity="0.6"/>

  <!-- tags -->
  <rect x="80" y="510" width="120" height="28" fill="rgba(0,200,255,0.08)" stroke="#00c8ff" stroke-width="1" stroke-opacity="0.3"/>
  <text x="140" y="529" font-family="monospace" font-size="10" letter-spacing="2" fill="#00c8ff" text-anchor="middle">LOGO DESIGN</text>

  <rect x="212" y="510" width="140" height="28" fill="rgba(0,200,255,0.08)" stroke="#00c8ff" stroke-width="1" stroke-opacity="0.3"/>
  <text x="282" y="529" font-family="monospace" font-size="10" letter-spacing="2" fill="#00c8ff" text-anchor="middle">AI PRODUCTIVITY</text>

  <rect x="364" y="510" width="120" height="28" fill="rgba(0,200,255,0.08)" stroke="#00c8ff" stroke-width="1" stroke-opacity="0.3"/>
  <text x="424" y="529" font-family="monospace" font-size="10" letter-spacing="2" fill="#00c8ff" text-anchor="middle">MARKETING</text>

  <!-- right side decorative radar rings -->
  <circle cx="980" cy="315" r="60"  fill="none" stroke="#00c8ff" stroke-width="0.5" opacity="0.15"/>
  <circle cx="980" cy="315" r="120" fill="none" stroke="#00c8ff" stroke-width="0.5" opacity="0.10"/>
  <circle cx="980" cy="315" r="180" fill="none" stroke="#00c8ff" stroke-width="0.5" opacity="0.07"/>
  <circle cx="980" cy="315" r="240" fill="none" stroke="#00c8ff" stroke-width="0.5" opacity="0.04"/>
  <circle cx="980" cy="315" r="8"   fill="#00c8ff" opacity="0.8"/>
  <circle cx="980" cy="315" r="4"   fill="#ffffff" opacity="0.9"/>

  <!-- data lines right -->
  <line x1="860" y1="200" x2="1150" y2="200" stroke="#00c8ff" stroke-width="0.5" opacity="0.1"/>
  <line x1="860" y1="430" x2="1150" y2="430" stroke="#ffa500" stroke-width="0.5" opacity="0.1"/>

  <!-- bottom bar -->
  <rect x="0" y="607" width="1200" height="1" fill="url(#line)" opacity="0.4"/>
  <text x="80" y="625" font-family="monospace" font-size="10" letter-spacing="3" fill="#3a6a85">DENYSOFT.COM // EL SALVADOR · CANADA · LATIN AMERICA</text>
  <text x="1120" y="625" font-family="monospace" font-size="10" letter-spacing="2" fill="#3a6a85" text-anchor="end">2026</text>
</svg>
